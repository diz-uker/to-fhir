{%- macro enum_class(enum) -%}
class {{ enum.class_name }}(Enum):
{% for concept in enum.concepts %}
    {{ concept.constant_name }} = ({{ concept.code | pyrepr }}, {{ concept.display | pyrepr }})
{% endfor %}
    def __init__(self, code: str, display: str | None) -> None:
        self.code = code
        self.display = display

    def coding(self) -> Coding:
        """Returns a new `Coding` for this concept, with system ``{{ enum.system }}``."""
        return Coding(system={{ enum.system | pyrepr }}, code=self.code, display=self.display)

    @classmethod
    def from_value(cls, code: str) -> Self:
        """Looks up the member whose ``code`` equals ``code``.

        Raises:
            ValueError: if no member has that code.
        """
        for member in cls:
            if member.code == code:
                return member
        raise ValueError(f"Unknown code: {code}")
{%- endmacro -%}

